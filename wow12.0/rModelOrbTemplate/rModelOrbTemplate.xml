<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
  <Script file="rModelOrbTemplate.lua" />

  <Frame name="rModelOrbTemplate" mixin="rModelOrbTemplateMixin" virtual="true">
    <Size x="256" y="256" />
    <Frames>
      <StatusBar parentKey="FillingStatusBar" mixin="rModelOrbFillingMixin" frameLevel="1">
        <BarTexture file="Interface\AddOns\rModelOrbTemplate\media\orb_filling16" />
        <BarColor r="1" g="1" b="1" a="1" />
        <Size x="256" y="256" />
        <Anchors>
          <Anchor point="BOTTOMLEFT" />
        </Anchors>
        <Scripts>
          <OnLoad method="OnLoad" />
          <OnValueChanged method="OnValueChanged" />
          <OnShow method="OnShow" />
          <OnHide method="OnHide" />
        </Scripts>
      </StatusBar>
      <Frame parentKey="ClipFrame" mixin="rModelOrbClipMixin" frameLevel="2">
        <Size x="256" y="256" />
        <Anchors>
          <Anchor point="BOTTOMLEFT" />
        </Anchors>
        <Frames>
          <ModelScene parentKey="ModelFrame" inherits="ModelSceneMixinTemplate">
            <Size x="256" y="256" />
            <Anchors>
              <Anchor point="BOTTOMLEFT" />
            </Anchors>
          </ModelScene>
        </Frames>
        <Scripts>
          <OnLoad method="OnLoad" />
          <OnShow method="OnShow" />
          <OnHide method="OnHide" />
        </Scripts>
      </Frame>
      <Frame parentKey="OverlayFrame" mixin="rModelOrbOverlayMixin" frameLevel="3">
        <Anchors>
          <Anchor point="TOPLEFT" />
          <Anchor point="BOTTOMRIGHT" />
        </Anchors>
        <Layers>
          <Layer level="BACKGROUND" textureSubLevel="-4">
            <Texture parentKey="SparkTexture" file="Interface\AddOns\rModelOrbTemplate\media\orb_spark"
              hidden="true">
              <Color r="1" g="1" b="1" a="1" />
              <Anchors>
                <Anchor point="TOP" />
              </Anchors>
            </Texture>
          </Layer>
          <Layer level="BACKGROUND" textureSubLevel="-3">
            <Texture parentKey="GlowTexture" file="Interface\AddOns\rModelOrbTemplate\media\orb_glow">
              <Color r="0" g="1" b="0" a="0" />
              <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
              </Anchors>
            </Texture>
          </Layer>
          <Layer level="BACKGROUND" textureSubLevel="-2">
            <Texture parentKey="LowHealthTexture" file="Interface\AddOns\rModelOrbTemplate\media\orb_glow2">
              <Color r="1" g="0" b="0" a="0" />
              <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
              </Anchors>
            </Texture>
          </Layer>
          <Layer level="BACKGROUND" textureSubLevel="-1">
            <Texture parentKey="GlossTexture" file="Interface\AddOns\rModelOrbTemplate\media\orb_gloss">
              <Color r="1" g="1" b="1" a="1" />
              <Anchors>
                <Anchor point="TOPLEFT" />
                <Anchor point="BOTTOMRIGHT" />
              </Anchors>
            </Texture>
          </Layer>
        </Layers>
        <Scripts>
          <OnLoad method="OnLoad" />
          <OnShow method="OnShow" />
          <OnHide method="OnHide" />
        </Scripts>
      </Frame>
    </Frames>
    <Layers>
      <Layer level="BACKGROUND" textureSubLevel="-6">
        <Texture parentKey="BackgroundTexture"
          file="Interface\AddOns\rModelOrbTemplate\media\orb_background">
          <Color r="1" g="1" b="1" a="1" />
          <Anchors>
            <Anchor point="TOPLEFT" />
            <Anchor point="BOTTOMRIGHT" />
          </Anchors>
        </Texture>
      </Layer>
    </Layers>
    <Scripts>
      <OnLoad method="OnLoad" />
      <OnShow method="OnShow" />
      <OnHide method="OnHide" />
    </Scripts>
  </Frame>
</Ui>